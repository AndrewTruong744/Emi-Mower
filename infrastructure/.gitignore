# Log files
*.log
*.layout

# Local variable files containing secrets (NEVER CHECK THESE IN)
*.tfvars
*.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# Ignore explicit credentials files you might have copied locally
credentials.json
*.pem
*.json

# Ignore the local state tracking files
# (These contain plain-text secrets and should be stored in a secure cloud bucket instead)
*.tfstate
*.tfstate.*

# Ignore crash logs
crash.log
crash.*

# Ignore the hidden .terraform directory 
# (This contains downloaded plugins, provider binaries, and environment metadata)
.terraform/

# Ignore override files (used for temporary local tweaks)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc